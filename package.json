{
  "name": "coldscript",
  "type": "module",
  "version": "0.1.5",
  "description": "Runtime companions to HotScript - typed JavaScript utilities for strings, numbers, tuples, and objects whose return types are computed by HotScript.",
  "author": "tijn <hoi@tijn.dev>",
  "homepage": "https://github.com/tijnjh/coldscript#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tijnjh/coldscript.git"
  },
  "bugs": {
    "url": "https://github.com/tijnjh/coldscript/issues"
  },
  "keywords": [
    "coldscript",
    "hotscript",
    "typescript",
    "runtime",
    "type-level",
    "typed",
    "utilities",
    "strings",
    "numbers",
    "tuples",
    "objects"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "peerDependencies": {
    "hotscript": "^1.0.13"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "eslint": "^10.5.0",
    "hotscript": "^1.0.13",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
